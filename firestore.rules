rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // A signed-in user (including anonymous) may read/write only their own doc.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Public leaderboard: anyone may read; a user may write only their own entry.
    // NOTE: rating is client-reported for now — add a Cloud Function to validate
    // it server-side (anti-cheat) before this is truly competitive.
    match /leaderboard/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    // Everything else is denied by default.
  }
}
