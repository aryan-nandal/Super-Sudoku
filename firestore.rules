rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // A user owns their profile doc (display name, etc.).
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Raw solve events: a user may only CREATE their own, with sane,
      // immutable fields. The server reads these to compute the rating.
      match /solves/{solveId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null
          && request.auth.uid == userId
          && request.resource.data.difficultyIndex is int
          && request.resource.data.difficultyIndex >= 0
          && request.resource.data.difficultyIndex <= 5
          && request.resource.data.timeSeconds is int
          && request.resource.data.timeSeconds >= 1
          && request.resource.data.timeSeconds <= 86400
          && request.resource.data.mistakes is int
          && request.resource.data.mistakes >= 0
          && request.resource.data.mistakes <= 9999;
        allow update, delete: if false; // solves are immutable
      }
    }

    // Public leaderboard: anyone may read.
    //
    // FREE (Spark) model — the client writes its own entry; rules validate the
    // shape and bound the rating so blatantly bogus values are rejected. This is
    // honest-client (a determined cheater could still spoof within bounds).
    //
    // BLAZE (server-authoritative) model — replace the `allow write` below with
    // `allow write: if false;` and deploy the Cloud Function so only the Admin
    // SDK writes entries (full anti-cheat). Also flip
    // kServerAuthoritativeLeaderboard to true in the app.
    match /leaderboard/{userId} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.rating is int
        && request.resource.data.rating >= 0
        && request.resource.data.rating <= 3500
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() <= 24;
    }
    // Everything else is denied by default.
  }
}
